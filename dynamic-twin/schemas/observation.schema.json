{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qso.fabric/schemas/dynamic-twin/observation.schema.json",
  "title": "QSO Canonical Observation Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observation_id",
    "twin_id",
    "source_id",
    "source_type",
    "observation_type",
    "subject",
    "event_time",
    "ingestion_time",
    "payload",
    "provenance",
    "quality",
    "integrity"
  ],
  "properties": {
    "observation_id": {"type": "string", "minLength": 1},
    "twin_id": {"type": "string", "pattern": "^twin:"},
    "source_id": {"type": "string", "pattern": "^source:"},
    "source_type": {"type": "string", "minLength": 1},
    "observation_type": {
      "type": "string",
      "enum": ["state", "structure", "behavior", "performance", "metric", "event", "metadata"]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {"type": "string", "minLength": 1},
        "entity_id": {"type": "string", "minLength": 1}
      }
    },
    "event_time": {"type": "string", "format": "date-time"},
    "ingestion_time": {"type": "string", "format": "date-time"},
    "sequence": {"type": ["integer", "null"], "minimum": 0},
    "schema_ref": {"type": ["string", "null"]},
    "payload": {"type": "object"},
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["collector", "pipeline"],
      "properties": {
        "collector": {"type": "string", "minLength": 1},
        "pipeline": {"type": "array", "items": {"type": "string"}}
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completeness", "reliability", "clock_confidence"],
      "properties": {
        "completeness": {"type": "number", "minimum": 0, "maximum": 1},
        "reliability": {"type": "number", "minimum": 0, "maximum": 1},
        "clock_confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_hash", "signature", "nonce", "timestamp", "authorized_source"],
      "properties": {
        "content_hash": {"type": "string", "pattern": "^sha256:"},
        "signature": {"type": "string", "minLength": 1},
        "nonce": {"type": "string", "minLength": 1},
        "timestamp": {"type": "string", "format": "date-time"},
        "authorized_source": {"type": "boolean", "const": true}
      }
    }
  }
}